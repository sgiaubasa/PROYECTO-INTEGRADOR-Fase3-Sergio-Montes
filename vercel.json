{
  "version": 2,
  "builds": [
    {
      "src": "backend/public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    /* Archivos públicos del backend */
    {
      "src": "^/api/public/(.*)$",
      "dest": "backend/public/$1"
    },

    /* Endpoints de la API (Express) */
    {
      "src": "^/api/(.*)$",
      "dest": "api/index.js"
    },

    /* Archivos estáticos generados por el build del frontend */
    {
      "src": "/(.*\\.(js|css|ico|png|jpg|jpeg|ttf|svg|webp|woff|woff2|map))",
      "dest": "/$1"
    },

    /* Fallback SPA (para React Router u otras rutas del front) */
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
